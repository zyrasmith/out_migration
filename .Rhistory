temp <- analytic_df %>%
mutate(decision_reg_roll = if_else(is.na(decision_reg_roll), "Rolling", decision_reg_roll)) %>%
mutate(deadline_burden = case_when(
((decision_reg_roll == "Rolling") & (!is.na(decision_ea) | !is.na(decision_eaii)) & (!is.na(decision_ed) | !is.na(decision_edii))) ~ "Early decision, early action, & rolling deadlines",
((decision_reg_roll == "Rolling") & (!is.na(decision_ed) | !is.na(decision_edii))) ~ "Early decision & rolling deadlines",
((decision_reg_roll == "Rolling") & (!is.na(decision_ea) | !is.na(decision_eaii) | !is.na(decision_restrictive_ea))) ~ "Early action & rolling deadlines",
decision_reg_roll == "Rolling" ~ "Rolling only",
((decision_reg_roll != "Rolling") & (!is.na(decision_ea) | !is.na(decision_eaii)) & (!is.na(decision_ed) | !is.na(decision_edii))) ~ "Early decision, early action, & regular deadlines",
((decision_reg_roll != "Rolling") & (!is.na(decision_ed) | !is.na(decision_edii))) ~ "Early decision & regular deadlines",
((decision_reg_roll != "Rolling") & (!is.na(decision_ea) | !is.na(decision_eaii) | !is.na(decision_restrictive_ea))) ~ "Early action & regular deadlines",
decision_reg_roll != "Rolling" ~ "Regular only",
TRUE ~ NA),
fee_burden = case_when(app_fee == 0 ~ "No fee",
app_fee <= 50 ~ "Low fee",
app_fee > 50 ~ "High fee",
TRUE ~ NA),
essay_burden = if_else(is.na(personal_essay), 0, 1),
self_report_burden = if_else(is.na(courses_grades), 0, 1),
writing_burden = if_else(is.na(writing_supplement), 0, 1),
test_burden = case_when(
test_policy == "A" ~ "Test always required",
test_policy == "S" ~ "Test sometimes required",
test_policy == "F" ~ "Test flexible policy",
test_policy == "I" ~ "Test ignored",
test_policy == "N" ~ "Test never required",
TRUE ~ NA),
recommendation_counselor = if_else(recommendation_counselor == "Y", 1, 0),
recommendation_counselor = replace_na(recommendation_counselor, 0),
recommendations_num_teacher = replace_na(recommendations_num_teacher, 0),
recommendation_num_other = replace_na(recommendations_num_other, 0)) %>%
rowwise() %>%
mutate(recommendation_burden = sum(c_across(c("recommendation_counselor", "recommendations_num_teacher", "recommendations_num_other")), na.rm = TRUE
),
midreport_burden = case_when(midyear_report == "Y"  ~ 1,
TRUE ~ 0))
