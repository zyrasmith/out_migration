#Categorical latent class models
model_2 = stepmix(
n_components = 2, #number of latent classes
n_steps = 3, # use the Vermunt 3-step method
correction = "ML", #Run maximum likelihood estimation to adjust for classification error (bias), using this instead of BCH because ML can be used to estimate categorical distal outcomes while BCH cannot
measurement = "categorical", #indicates the use of categorical data in the measurement model to predict latent classes
structural = "covariate", #indicates the use of multinomial logistic regression model
assignment = "soft", #retains the probabilities over each latent class instead of assigning a value of "1" to the most likely class
verbose = 1, #print detailed output
random_state = 123
)
model_3 = stepmix(
indicator_vars,
covariates,
n_components = 3,
n_steps = 3,
correction = "ML",
measurement = "categorical",
structural = "covariate",
assignment = "soft",
verbose = 1,
random_state = 123
)
m2 <- fit(model_2, X = indicator_vars, Y = covariates)
m3 <- fit(model_3, X = indicator_vars, Y = covariates)
