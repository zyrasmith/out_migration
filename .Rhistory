filter(!is.na(tot_pop),
!is.na(perc_ba),
!is.na(med_income),
!is.na(perc_pov),
!is.na(perc_white),
!is.na(perc_black),
!is.na(perc_hisp),
!is.na(perc_asian))
set.seed(1234)
msas2 <- multiLCA(
data = data_mlca2,
Y = Y,
iT = 7,
id_high = "cbsa",
iM = 3,
Zh = Zh
)
