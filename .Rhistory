)
data_mlca1 |> count(cbsa, name = "n_institutions") |> summary() # number of institutions within a CBSA
data_mlca0 <- data |>
filter(!is.na(cbsa),
!is.na(public),
!is.na(twoyear),
!is.na(size),
!is.na(msi),
!is.na(rurality),
!is.na(asc))
glimpse(data_mlca0)
